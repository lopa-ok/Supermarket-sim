[gd_scene load_steps=3 format=3]

[ext_resource type="Script" path="res://Scripts/UI/stock_panel.gd" id="1_stock"]
[ext_resource type="Theme" path="res://Resources/ui_theme.tres" id="2_theme"]

[node name="StockPanel" type="PanelContainer"]
layout_mode = 1
anchors_preset = 1
anchor_left = 1.0
anchor_right = 1.0
offset_left = -250.0
offset_top = 54.0
offset_right = -8.0
offset_bottom = -8.0
grow_horizontal = 0
mouse_filter = 2
theme = ExtResource("2_theme")
script = ExtResource("1_stock")

[node name="Scroll" type="ScrollContainer" parent="."]
layout_mode = 2
mouse_filter = 2

[node name="VBox" type="VBoxContainer" parent="Scroll"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 6

[node name="StockHeader" type="Label" parent="Scroll/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(0.5, 0.65, 0.9, 1)
theme_override_font_sizes/font_size = 14
text = "── STOCK ──"
horizontal_alignment = 1

[node name="StockList" type="VBoxContainer" parent="Scroll/VBox"]
unique_name_in_owner = true
layout_mode = 2
theme_override_constants/separation = 2

[node name="Sep" type="HSeparator" parent="Scroll/VBox"]
layout_mode = 2

[node name="AlertHeader" type="Label" parent="Scroll/VBox"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 0.6, 0.25, 1)
theme_override_font_sizes/font_size = 14
text = "── ALERTS ──"
horizontal_alignment = 1

[node name="AlertList" type="VBoxContainer" parent="Scroll/VBox"]
unique_name_in_owner = true
layout_mode = 2
theme_override_constants/separation = 2
